# Environment variables for local development and build.
# Copy this file to `.env` and fill in the values you want to enable.
# `.env` is gitignored — never commit secrets or your live URLs.

# =========================================================================
# Client-side (VITE_*): exposed to the browser via import.meta.env.
# Safe to set in production builds. NOT for secrets.
# =========================================================================

# Cloudflare Worker URL — the "relay" that handles Problem Reports and
# publishes game logs to the public repo on game-end. Leave blank in dev to
# fall back to the local Vite middleware (writes to disk under
# training-logs/problem-reports/ instead of filing a real GitHub Issue).
#
# Deployed default: https://tyrants-relay.johnchampaign.workers.dev
VITE_TOTU_RELAY_URL=

# Base URL where card and board art live. The first time the app loads it
# fetches every image from this base into the browser's IndexedDB (one-time);
# subsequent loads serve them from the local store, no network needed. The
# base should mirror the `assets/` tree, so `assets/cards/01-unnamed.jpg`
# becomes `<base>/cards/01-unnamed.jpg`.
#
# Leave blank in dev to use the locally-extracted assets at `/cards/*` (run
# `npm run extract-assets` first). For the deployed game, point this at an
# Imgur mirror, your own R2/S3 bucket, or another image-friendly host.
VITE_TOTU_IMAGE_BASE_URL=

# =========================================================================
# Server-side dev fallbacks (no VITE_ prefix): read by the Vite middleware
# in vite.config.ts. Only consulted when VITE_TOTU_RELAY_URL is unset.
# Lets you exercise the GitHub round-trip locally without deploying the
# Worker. Keep secret — these never leave your machine.
# =========================================================================

# A GitHub Personal Access Token (fine-grained) with Contents + Issues
# read/write on the target repo. Same scopes as the Worker's GITHUB_TOKEN
# secret, but used only by the local Vite middleware.
TOTU_BUGREPORT_TOKEN=

# The target repo in `owner/repo` form. Issues filed by the local
# middleware land here.
TOTU_BUGREPORT_REPO=johnchampaign/tyrants-of-the-underdark
