# Optional environment variables consumed by the Vite dev server middleware
# (see vite.config.ts). Copy this file to `.env` and fill in the values you
# want to enable.
#
# When BOTH variables are set, the in-game "Report a problem" button submits
# directly to the named GitHub repo as a new Issue. When unset, problem reports
# are saved to disk under training-logs/problem-reports/ instead — the button
# still works, just with no GitHub round-trip.

# A GitHub Personal Access Token (classic or fine-grained) with `repo` scope
# (or, for fine-grained, "Issues: read and write" on the target repo).
# Keep this secret — it never leaves the local dev server.
TOTU_BUGREPORT_TOKEN=

# The target repo in `owner/repo` form. Create it on GitHub first if it
# doesn't exist; the issue creator must be able to write to it.
TOTU_BUGREPORT_REPO=johnchampaign/tyrants-of-the-underdark
